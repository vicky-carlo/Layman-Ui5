<mvc:View
    controllerName="masterdetail.masterdetail.controller.order"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
>
    <Page id="page">
        <customHeader>
            <OverflowToolbar>
                <content>
                    <ToolbarSpacer />
                    <Title text="Order Summary Master Detail" />
                    <ToolbarSpacer />
                </content>
            </OverflowToolbar>
        </customHeader>
        <content >
            <SplitContainer id="splitCont" initialMaster="master" initialDetail="orderDetail">
                    
                    <detailPages>
                        <Page id="orderDetail" title="Order Details">
                            <Table id="orderTable" items="{/Order_Details}">
                                <columns>
                                    <Column>
                                        <Text text="Order ID" />
                                        
                                    </Column>
                                    <Column>
                                        <Text text="Product ID" />
                                    </Column>
                                    <Column>
                                        <Text text="Unit Price" />
                                    </Column>
                                    <Column>
                                        <Text text="Quantity" />
                                    </Column>
                                    <Column>
                                        <Text text="Discount" />
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Navigation" press="onPressOrderDetail">
                                        <cells>
                                            <Text text="{OrderID}" />
                                            <Text text="{ProductID}" />
                                            <Text text="{UnitPrice}" />
                                            <Text text="{Quantity}" />
                                            <Text text="{Discount}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </Page>
                        <Page showNavButton="true" navButtonPress="onProductBack" id="productsDetail" title="Product">
                            <VBox >
                                <f:SimpleForm id="productForm" editable="false" labelSpanL="3" labelSpanXL="3" labelSpanM="3" labelSpanS="12" columnsXL="1" columnsL="1" columnsM="1" emptySpanL="4" emptySpanM="4" emptySpanS="0" emptySpanXL="4" layout="ResponsiveGridLayout" >
                                    <f:content>
                                        
                                        <Label text="Product Name" />
                                        <Text text="{/ProductName}" />
                                        <Label text="Supplier ID" />
                                        <Text text="{/SupplierID}" />
                                        <Label text="Quality Per Unit" />
                                        <Text text="{/QualityPerUnit}" />
                                        <Label text="Unit Price" />
                                        <Text text="{/UnitPrice}" />
                                        <Label text="Unit On Order" />
                                        <Text text="{/UnitOnOrder}" />
                                    </f:content>
                                </f:SimpleForm>
                            </VBox>

                        </Page>
                    </detailPages>
                    <masterPages>
                        <Page id="master" title="Order Master">
                            <List id="OrderList" items="{/Orders}" itemPress="onListPress">
                                <items>
                                    <StandardListItem title="{OrderID}" type="Navigation"/>
                                </items>
                                
                            </List>
                        </Page>
                    </masterPages>   
            </SplitContainer>
        </content>
    </Page>
</mvc:View>
